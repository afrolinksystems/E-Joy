# E-Joy admin-web environment
# Copy to apps/admin-web/.env for local development.
# Configure the same keys in the Vercel admin-web project for production.

# Backend GraphQL endpoints
VITE_GRAPHQL_URL=http://localhost:9602/graphql
VITE_GRAPHQL_WS_URL=ws://localhost:9602/graphql

# Backend origin for REST uploads
VITE_ORDER_SERVICE_ORIGIN=http://localhost:9602

# Customer app URL used when generating table QR/deep links
VITE_CUSTOMER_WEB_URL=http://localhost:9601

# Better Stack Sentry-compatible frontend error tracking
# Leave empty locally unless you intentionally want local errors sent.
VITE_BETTER_STACK_SENTRY_DSN=
VITE_APP_ENV=development
VITE_APP_RELEASE=local
