# E-Joy mawa-web environment
# Copy to apps/mawa-web/.env for local development.
# Configure the same keys in its deployment project if deployed.

# GraphQL HTTP endpoint
VITE_GRAPHQL_URL=http://localhost:9602/graphql

# Shop whose menu is shown and where createOrder is sent (matches prisma seed default)
VITE_DEFAULT_SHOP_ID=test-shop-001

# Public customer ordering URL linked from the site
VITE_ORDERING_URL=http://localhost:9601
