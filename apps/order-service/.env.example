# E-Joy order-service environment
# Copy this file to apps/order-service/.env for local development, or use these
# keys in Render environment variables for production.

# Runtime
NODE_ENV=production
PORT=3000
SERVICE_NAME=order-service
APP_RELEASE=<git-sha-or-release-version>

# Database / Cache
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
LOCAL_DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<database>
REDIS_URL=redis://localhost:6379

# CORS / Frontend URLs
CORS_ORIGINS=https://admin.example.com,https://super-admin.example.com,https://customer.example.com
CUSTOMER_WEB_ORIGIN=https://customer.example.com

# Authentication
JWT_ACCESS_SECRET=<replace-with-strong-random-secret-32-plus-chars>
JWT_REFRESH_SECRET=<replace-with-different-strong-random-secret-32-plus-chars>
JWT_ISSUER=ejoy
JWT_AUDIENCE=ejoy-apps
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
REFRESH_COOKIE_NAME=ejoy_refresh
COOKIE_DOMAIN=.example.com
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
BCRYPT_COST=12
AUTH_DEMO_MODE=false
ADMIN_SENSITIVE_OP_CODE=<replace-with-step-up-code>

# Better Stack logs and Sentry-compatible error tracking
LOG_LEVEL=info
LOG_TO_BETTER_STACK=true
BETTER_STACK_INGEST_URL=https://in.logs.betterstack.com
BETTER_STACK_SOURCE_TOKEN=<order-service-production-logs-source-token>
BETTER_STACK_SENTRY_DSN=<order-service-sentry-compatible-dsn>

# Uploads / Cloudinary
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>
CLOUDINARY_UPLOAD_FOLDER=ejoy/menu
