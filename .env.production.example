# Runtime
NODE_ENV=production
PORT=3000

# Database / Cache / MQ
DATABASE_URL=postgresql://<user>:<pass>@<host>:5433/<db>
REDIS_URL=redis://<host>:6379
KAFKA_BROKERS=<host1:9092,host2:9092>
KAFKA_CLIENT_ID=order-service

# GraphQL / Auth
JWT_ACCESS_SECRET=<replace-with-strong-random-secret-32-plus-chars>
JWT_REFRESH_SECRET=<replace-with-different-strong-random-secret-32-plus-chars>
JWT_ISSUER=ejoy
JWT_AUDIENCE=ejoy-apps
ACCESS_TOKEN_TTL_SECONDS=120
# REFRESH_TOKEN_TTL_SECONDS=1209600
REFRESH_TOKEN_TTL_SECONDS=300
REFRESH_COOKIE_NAME=ejoy_refresh
COOKIE_DOMAIN=.example.com
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
BCRYPT_COST=12
AUTH_DEMO_MODE=false
ADMIN_SENSITIVE_OP_CODE=<replace-with-step-up-code>
CORS_ORIGINS=https://admin.example.com,https://super-admin.example.com,https://customer.example.com

# Payment
TELEBIRR_APP_SECRET=<replace-with-provider-secret>
TELEBIRR_PUBLIC_KEY=<replace-with-provider-public-key>

# Frontend runtime
VITE_GRAPHQL_URL=https://api.example.com/graphql
