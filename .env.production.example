# Runtime
NODE_ENV=production
PORT=3000

# Database / Cache / MQ
DATABASE_URL=postgresql://<user>:<pass>@<host>:5433/<db>
REDIS_URL=redis://<host>:6379
KAFKA_BROKERS=<host1:9092,host2:9092>
KAFKA_CLIENT_ID=order-service

# GraphQL / Auth
JWT_SECRET=<replace-with-strong-random-secret>

# Payment
TELEBIRR_APP_SECRET=<replace-with-provider-secret>
TELEBIRR_PUBLIC_KEY=<replace-with-provider-public-key>

# Frontend runtime
VITE_GRAPHQL_URL=https://api.example.com/graphql
